{% liquid
  assign bg_color = section.settings.background_color | default: '#1a1a1a'
  assign txt_color = section.settings.text_color | default: '#FFFFFF'
%}

<div
  class="shopcom-announcement-bar"
  {% if section.settings.show_on_mobile %}data-show-mobile="true"{% endif %}
  style="
    --announcement-bg: {{ bg_color }};
    --announcement-text: {{ txt_color }};
  "
>
  <div class="shopcom-announcement-bar__inner">
    <div class="shopcom-announcement-bar__left">
      <span class="shopcom-announcement-bar__text">{{ section.settings.left_text }}</span>
      {% if section.settings.left_link_url != blank %}
        <a href="{{ section.settings.left_link_url }}" class="shopcom-announcement-bar__link">
          {{ section.settings.left_link_text }}
        </a>
      {% else %}
        <span class="shopcom-announcement-bar__link-text">{{ section.settings.left_link_text }}</span>
      {% endif %}
    </div>

    <div class="shopcom-announcement-bar__right">
      {% if section.settings.right_url != blank %}
        <a href="{{ section.settings.right_url }}" class="shopcom-announcement-bar__link">
          {{ section.settings.right_text }}
        </a>
      {% else %}
        <span class="shopcom-announcement-bar__text">{{ section.settings.right_text }}</span>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .shopcom-announcement-bar {
    background-color: var(--announcement-bg, #1a1a1a);
    color: var(--announcement-text, #FFFFFF);
    font-family: 'DM Sans', var(--font-body--family), sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.4;
    padding-block: 8px;
  }

  .shopcom-announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--narrow-page-width, 90rem);
    margin-inline: auto;
    padding-inline: var(--padding-md, 1rem);
    gap: 16px;
  }

  .shopcom-announcement-bar__left {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }

  .shopcom-announcement-bar__link {
    color: var(--announcement-text, #FFFFFF);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .shopcom-announcement-bar__link:hover {
    opacity: 0.8;
  }

  .shopcom-announcement-bar__link:focus-visible {
    outline: 2px solid var(--announcement-text, #FFFFFF);
    outline-offset: 2px;
  }

  .shopcom-announcement-bar__link-text {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media screen and (max-width: 749px) {
    .shopcom-announcement-bar__inner {
      flex-direction: column;
      gap: 4px;
      text-align: center;
    }

    .shopcom-announcement-bar__left {
      justify-content: center;
    }

    .shopcom-announcement-bar:not([data-show-mobile="true"]) {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.shopcom_announcement_bar",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "left_text",
      "label": "Left text",
      "default": "Your Shop Consultant is"
    },
    {
      "type": "text",
      "id": "left_link_text",
      "label": "Left link text",
      "default": "SHOP.COM"
    },
    {
      "type": "url",
      "id": "left_link_url",
      "label": "Left link URL"
    },
    {
      "type": "text",
      "id": "right_text",
      "label": "Right text",
      "default": "Start Your SHOP.COM Business"
    },
    {
      "type": "url",
      "id": "right_url",
      "label": "Right link URL"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": true
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
