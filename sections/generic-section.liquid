{% doc %}
  Generic Section

  A simple styled wrapper section with 2-breakpoint (mobile/desktop) settings
  for background color, text color, padding, and margin. Accepts any theme blocks.

  @example
  Used via template JSON with type: "generic-section"
{% enddoc %}

{% comment %}
  == AI DOCUMENTATION ==

  ▸ PURPOSE
  Primary building-block section for custom pages. Provides a simple styled
  wrapper with 2-breakpoint (mobile/desktop) background color, text color,
  padding, and margin settings. Accepts any combination of theme and app blocks.

  ▸ CONTEXT
  - Parent: template JSON (e.g., templates/index.json, templates/page.*.json)
  - Children: any @theme or @app blocks (hero-block, grid-row, carousel-block,
    tab-navigation, tab-content, text, button, group, image, video, etc.)
  - Used extensively across the theme — templates/index.json contains 13+
    instances of generic-section for homepage composition
  - CSS class: .generic-section (with .section-wrapper from schema "class" property)

  ▸ KEY SCHEMA SETTINGS
  Per breakpoint (mobile / desktop):
  - background_color_{bp} (color): section background
  - text_color_{bp} (color): inheritable text color
  - padding_top/bottom/left/right_{bp} (number, px)
  - margin_bottom_{bp} (number, px)

  ▸ USAGE EXAMPLES
  Template JSON — section wrapping a hero + text blocks:
    {
      "hero_section_A1b2C3": {
        "type": "generic-section",
        "settings": {
          "padding_top_mobile": 0,
          "padding_bottom_mobile": 0,
          "padding_top_desktop": 0,
          "padding_bottom_desktop": 0
        },
        "blocks": {
          "hero_D4e5F6": {
            "type": "hero-block",
            "settings": { "height_type_desktop": "custom", "custom_height_desktop": 600 },
            "blocks": {
              "heading_G7h8I9": { "type": "text", "settings": { "text": "<h1>Welcome</h1>" } },
              "cta_J0k1L2": { "type": "button", "settings": { "label": "Shop", "link": "shopify://collections/all" } }
            },
            "block_order": ["heading_G7h8I9", "cta_J0k1L2"]
          }
        },
        "block_order": ["hero_D4e5F6"]
      }
    }

  Template JSON — section with grid layout:
    {
      "features_M3n4O5": {
        "type": "generic-section",
        "settings": {
          "background_color_desktop": "#F5F5F5",
          "padding_top_desktop": 80,
          "padding_bottom_desktop": 80,
          "padding_left_desktop": 40,
          "padding_right_desktop": 40,
          "padding_top_mobile": 40,
          "padding_bottom_mobile": 40,
          "padding_left_mobile": 16,
          "padding_right_mobile": 16
        },
        "blocks": {
          "row_P6q7R8": {
            "type": "grid-row",
            "settings": { "column_gap_desktop": 24 },
            "blocks": {
              "col1_S9t0U1": { "type": "_grid-column", "settings": { "column_span_mobile": "12", "column_span_desktop": "4" } },
              "col2_V2w3X4": { "type": "_grid-column", "settings": { "column_span_mobile": "12", "column_span_desktop": "4" } },
              "col3_Y5z6A7": { "type": "_grid-column", "settings": { "column_span_mobile": "12", "column_span_desktop": "4" } }
            },
            "block_order": ["col1_S9t0U1", "col2_V2w3X4", "col3_Y5z6A7"]
          }
        },
        "block_order": ["row_P6q7R8"]
      }
    }
{% endcomment %}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<div
  class="generic-section"
  style="
    --gs-bg-mobile: {{ section.settings.background_color_mobile }};
    --gs-bg-desktop: {{ section.settings.background_color_desktop }};
    --gs-text-mobile: {{ section.settings.text_color_mobile }};
    --gs-text-desktop: {{ section.settings.text_color_desktop }};
    --gs-pt-mobile: {{ section.settings.padding_top_mobile | default: 0 }}px;
    --gs-pb-mobile: {{ section.settings.padding_bottom_mobile | default: 0 }}px;
    --gs-pl-mobile: {{ section.settings.padding_left_mobile | default: 0 }}px;
    --gs-pr-mobile: {{ section.settings.padding_right_mobile | default: 0 }}px;
    --gs-pt-desktop: {{ section.settings.padding_top_desktop | default: 0 }}px;
    --gs-pb-desktop: {{ section.settings.padding_bottom_desktop | default: 0 }}px;
    --gs-pl-desktop: {{ section.settings.padding_left_desktop | default: 0 }}px;
    --gs-pr-desktop: {{ section.settings.padding_right_desktop | default: 0 }}px;
    --gs-mb-mobile: {{ section.settings.margin_bottom_mobile | default: 0 }}px;
    --gs-mb-desktop: {{ section.settings.margin_bottom_desktop | default: 0 }}px;
  "
>
  {{- children -}}
</div>

{% stylesheet %}
  .generic-section {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .generic-section {
      background-color: var(--gs-bg-mobile);
      color: var(--gs-text-mobile);
      padding-block-start: var(--gs-pt-mobile, 0px);
      padding-block-end: var(--gs-pb-mobile, 0px);
      padding-inline-start: var(--gs-pl-mobile, 0px);
      padding-inline-end: var(--gs-pr-mobile, 0px);
      margin-block-end: var(--gs-mb-mobile, 0px);
    }
  }

  @media screen and (min-width: 750px) {
    .generic-section {
      background-color: var(--gs-bg-desktop);
      color: var(--gs-text-desktop);
      padding-block-start: var(--gs-pt-desktop, 0px);
      padding-block-end: var(--gs-pb-desktop, 0px);
      padding-inline-start: var(--gs-pl-desktop, 0px);
      padding-inline-end: var(--gs-pr-desktop, 0px);
      margin-block-end: var(--gs-mb-desktop, 0px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.generic_section",
  "tag": "section",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "color",
      "id": "background_color_mobile",
      "label": "t:settings.background_color_mobile"
    },
    {
      "type": "color",
      "id": "text_color_mobile",
      "label": "t:settings.text_color_mobile"
    },
    {
      "type": "number",
      "id": "padding_top_mobile",
      "label": "t:settings.padding_top_mobile",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom_mobile",
      "label": "t:settings.padding_bottom_mobile",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_left_mobile",
      "label": "t:settings.padding_left_mobile",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_right_mobile",
      "label": "t:settings.padding_right_mobile",
      "default": 0
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "label": "t:settings.margin_bottom_mobile",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.desktop"
    },
    {
      "type": "color",
      "id": "background_color_desktop",
      "label": "t:settings.background_color_desktop"
    },
    {
      "type": "color",
      "id": "text_color_desktop",
      "label": "t:settings.text_color_desktop"
    },
    {
      "type": "number",
      "id": "padding_top_desktop",
      "label": "t:settings.padding_top_desktop",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom_desktop",
      "label": "t:settings.padding_bottom_desktop",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_left_desktop",
      "label": "t:settings.padding_left_desktop",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_right_desktop",
      "label": "t:settings.padding_right_desktop",
      "default": 0
    },
    {
      "type": "number",
      "id": "margin_bottom_desktop",
      "label": "t:settings.margin_bottom_desktop",
      "default": 0
    },
  ],
  "presets": [
    {
      "name": "t:names.generic_section",
      "category": "t:categories.layout"
    }
  ]
}
{% endschema %}
