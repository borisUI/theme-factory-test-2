{% doc %}
  Hero Block

  A layout block that renders a container with configurable height,
  background media (image or video), optional overlay, and nested child blocks.
  All settings are duplicated for mobile and desktop breakpoints.

  @example
  {% content_for 'block', type: 'hero-block', id: 'hero' %}
{% enddoc %}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

{% liquid
  assign pos_mobile = block.settings.content_position_mobile | default: 'center-center'
  assign pos_desktop = block.settings.content_position_desktop | default: 'center-center'

  assign pos_mobile_parts = pos_mobile | split: '-'
  assign pos_desktop_parts = pos_desktop | split: '-'

  case pos_mobile_parts[0]
    when 'top'
      assign hero_ai_mobile = 'flex-start'
    when 'center'
      assign hero_ai_mobile = 'center'
    when 'bottom'
      assign hero_ai_mobile = 'flex-end'
  endcase

  case pos_mobile_parts[1]
    when 'left'
      assign hero_jc_mobile = 'flex-start'
    when 'center'
      assign hero_jc_mobile = 'center'
    when 'right'
      assign hero_jc_mobile = 'flex-end'
  endcase

  case pos_desktop_parts[0]
    when 'top'
      assign hero_ai_desktop = 'flex-start'
    when 'center'
      assign hero_ai_desktop = 'center'
    when 'bottom'
      assign hero_ai_desktop = 'flex-end'
  endcase

  case pos_desktop_parts[1]
    when 'left'
      assign hero_jc_desktop = 'flex-start'
    when 'center'
      assign hero_jc_desktop = 'center'
    when 'right'
      assign hero_jc_desktop = 'flex-end'
  endcase
%}

<div
  class="hero-block"
  style="
    --hero-height-mobile: {% case block.settings.height_type_mobile %}{% when 'full_viewport' %}100dvh{% when 'custom' %}{{ block.settings.custom_height_mobile | default: 400 }}px{% else %}auto{% endcase %};
    --hero-height-desktop: {% case block.settings.height_type_desktop %}{% when 'full_viewport' %}100dvh{% when 'custom' %}{{ block.settings.custom_height_desktop | default: 400 }}px{% else %}auto{% endcase %};
    --hero-cw-mobile: {{ block.settings.content_width_mobile | default: '100' }}%;
    --hero-cw-desktop: {{ block.settings.content_width_desktop | default: '100' }}%;
    --hero-pt-mobile: {{ block.settings.padding_top_mobile | default: 0 }}px;
    --hero-pb-mobile: {{ block.settings.padding_bottom_mobile | default: 0 }}px;
    --hero-pl-mobile: {{ block.settings.padding_left_mobile | default: 0 }}px;
    --hero-pr-mobile: {{ block.settings.padding_right_mobile | default: 0 }}px;
    --hero-pt-desktop: {{ block.settings.padding_top_desktop | default: 0 }}px;
    --hero-pb-desktop: {{ block.settings.padding_bottom_desktop | default: 0 }}px;
    --hero-pl-desktop: {{ block.settings.padding_left_desktop | default: 0 }}px;
    --hero-pr-desktop: {{ block.settings.padding_right_desktop | default: 0 }}px;
    --hero-mb-mobile: {{ block.settings.margin_bottom_mobile | default: 0 }}px;
    --hero-mb-desktop: {{ block.settings.margin_bottom_desktop | default: 0 }}px;
    --hero-ai-mobile: {{ hero_ai_mobile }};
    --hero-jc-mobile: {{ hero_jc_mobile }};
    --hero-ai-desktop: {{ hero_ai_desktop }};
    --hero-jc-desktop: {{ hero_jc_desktop }};
  "
  {{ block.shopify_attributes }}
>
  <div class="hero-block__media-wrapper hero-block__media-wrapper--mobile">
    {% render 'background-media',
      background_media: block.settings.background_media_mobile,
      background_video: block.settings.video_mobile,
      background_video_position: block.settings.video_position_mobile,
      background_image: block.settings.image_mobile,
      background_image_position: block.settings.image_position_mobile
    %}
  </div>

  <div class="hero-block__media-wrapper hero-block__media-wrapper--desktop">
    {% render 'background-media',
      background_media: block.settings.background_media_desktop,
      background_video: block.settings.video_desktop,
      background_video_position: block.settings.video_position_desktop,
      background_image: block.settings.image_desktop,
      background_image_position: block.settings.image_position_desktop
    %}
  </div>

  {% if block.settings.toggle_overlay %}
    <div class="hero-block__overlay">
      {% render 'overlay', settings: block.settings, layer: '0' %}
    </div>
  {% endif %}

  <div class="hero-block__content">
    {{- children -}}
  </div>
</div>

{% stylesheet %}
  .hero-block {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    overflow: hidden;
  }

  .hero-block__media-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-block__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-block__content {
    position: relative;
    z-index: var(--layer-raised, 2);
    display: flex;
    flex-direction: column;
  }

  @media screen and (max-width: 749px) {
    .hero-block {
      height: var(--hero-height-mobile, auto);
      padding-block-start: var(--hero-pt-mobile, 0px);
      padding-block-end: var(--hero-pb-mobile, 0px);
      padding-inline-start: var(--hero-pl-mobile, 0px);
      padding-inline-end: var(--hero-pr-mobile, 0px);
      margin-block-end: var(--hero-mb-mobile, 0px);
      align-items: var(--hero-jc-mobile, center);
      justify-content: var(--hero-ai-mobile, center);
    }

    .hero-block__media-wrapper--desktop {
      display: none;
    }

    .hero-block__content {
      width: var(--hero-cw-mobile, 100%);
    }
  }

  @media screen and (min-width: 750px) {
    .hero-block {
      height: var(--hero-height-desktop, auto);
      padding-block-start: var(--hero-pt-desktop, 0px);
      padding-block-end: var(--hero-pb-desktop, 0px);
      padding-inline-start: var(--hero-pl-desktop, 0px);
      padding-inline-end: var(--hero-pr-desktop, 0px);
      margin-block-end: var(--hero-mb-desktop, 0px);
      align-items: var(--hero-jc-desktop, center);
      justify-content: var(--hero-ai-desktop, center);
    }

    .hero-block__media-wrapper--mobile {
      display: none;
    }

    .hero-block__content {
      width: var(--hero-cw-desktop, 100%);
    }
  }
{% endstylesheet %}

