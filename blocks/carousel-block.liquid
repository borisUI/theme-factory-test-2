{% doc %}
  Carousel Block

  A layout block that wraps child _carousel-slide blocks in a Swiper.js carousel.
  Supports responsive slides per view, gap, autoplay, arrows, and dots.

  @example
  {% content_for 'block', type: 'carousel-block', id: 'carousel-1' %}
{% enddoc %}

{% liquid
  assign slides_per_view_mobile = block.settings.slides_per_view_mobile | default: 1
  assign slides_per_view_tablet = block.settings.slides_per_view_tablet | default: 2
  assign slides_per_view_desktop = block.settings.slides_per_view_desktop | default: 3

  assign gap_mobile = block.settings.slide_gap_mobile | default: 16
  assign gap_tablet = block.settings.slide_gap_tablet | default: 20
  assign gap_desktop = block.settings.slide_gap_desktop | default: 24

  assign autoplay_mobile = block.settings.autoplay_mobile
  assign autoplay_tablet = block.settings.autoplay_tablet
  assign autoplay_desktop = block.settings.autoplay_desktop

  assign autoplay_delay_mobile = block.settings.autoplay_delay_mobile | default: 5
  assign autoplay_delay_tablet = block.settings.autoplay_delay_tablet | default: 5
  assign autoplay_delay_desktop = block.settings.autoplay_delay_desktop | default: 5

  assign show_arrows_mobile = block.settings.show_arrows_mobile
  assign show_arrows_tablet = block.settings.show_arrows_tablet
  assign show_arrows_desktop = block.settings.show_arrows_desktop

  assign external_arrows_mobile = block.settings.external_arrows_mobile
  assign external_arrows_tablet = block.settings.external_arrows_tablet
  assign external_arrows_desktop = block.settings.external_arrows_desktop

  assign show_dots_mobile = block.settings.show_dots_mobile
  assign show_dots_tablet = block.settings.show_dots_tablet
  assign show_dots_desktop = block.settings.show_dots_desktop

  assign any_arrows = show_arrows_mobile | default: false
  unless any_arrows
    assign any_arrows = show_arrows_tablet
  endunless
  unless any_arrows
    assign any_arrows = show_arrows_desktop
  endunless

  assign any_external_arrows = external_arrows_mobile | default: false
  unless any_external_arrows
    assign any_external_arrows = external_arrows_tablet
  endunless
  unless any_external_arrows
    assign any_external_arrows = external_arrows_desktop
  endunless

  assign any_internal_arrows = false
  if show_arrows_mobile and external_arrows_mobile == false
    assign any_internal_arrows = true
  endif
  if show_arrows_tablet and external_arrows_tablet == false
    assign any_internal_arrows = true
  endif
  if show_arrows_desktop and external_arrows_desktop == false
    assign any_internal_arrows = true
  endif

  assign any_dots = show_dots_mobile | default: false
  unless any_dots
    assign any_dots = show_dots_tablet
  endunless
  unless any_dots
    assign any_dots = show_dots_desktop
  endunless
%}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<carousel-block
  class="carousel-block"
  style="
    --carousel-mb-mobile: {{ block.settings.margin_bottom_mobile | default: 0 }}px;
    --carousel-mb-tablet: {{ block.settings.margin_bottom_tablet | default: 0 }}px;
    --carousel-mb-desktop: {{ block.settings.margin_bottom_desktop | default: 0 }}px;
  "
  data-slides-per-view-mobile="{{ slides_per_view_mobile }}"
  data-slides-per-view-tablet="{{ slides_per_view_tablet }}"
  data-slides-per-view-desktop="{{ slides_per_view_desktop }}"
  data-gap-mobile="{{ gap_mobile }}"
  data-gap-tablet="{{ gap_tablet }}"
  data-gap-desktop="{{ gap_desktop }}"
  data-autoplay-mobile="{{ autoplay_mobile }}"
  data-autoplay-tablet="{{ autoplay_tablet }}"
  data-autoplay-desktop="{{ autoplay_desktop }}"
  data-autoplay-delay-mobile="{{ autoplay_delay_mobile }}"
  data-autoplay-delay-tablet="{{ autoplay_delay_tablet }}"
  data-autoplay-delay-desktop="{{ autoplay_delay_desktop }}"
  data-show-arrows-mobile="{{ show_arrows_mobile }}"
  data-show-arrows-tablet="{{ show_arrows_tablet }}"
  data-show-arrows-desktop="{{ show_arrows_desktop }}"
  data-external-arrows-mobile="{{ external_arrows_mobile }}"
  data-external-arrows-tablet="{{ external_arrows_tablet }}"
  data-external-arrows-desktop="{{ external_arrows_desktop }}"
  data-show-dots-mobile="{{ show_dots_mobile }}"
  data-show-dots-tablet="{{ show_dots_tablet }}"
  data-show-dots-desktop="{{ show_dots_desktop }}"
  {{ block.shopify_attributes }}
>
  {% if any_arrows and any_external_arrows %}
    <button class="carousel-block__arrow carousel-block__arrow--prev" aria-label="{{ 'accessibility.slideshow_previous' | t }}">
      <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {% endif %}

  <div class="swiper" ref="swiperContainer">
    <div class="swiper-wrapper">
      {{- children -}}
    </div>

    {% if any_internal_arrows %}
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    {% endif %}

    {% if any_dots %}
      <div class="swiper-pagination"></div>
    {% endif %}
  </div>

  {% if any_arrows and any_external_arrows %}
    <button class="carousel-block__arrow carousel-block__arrow--next" aria-label="{{ 'accessibility.slideshow_next' | t }}">
      <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  {% endif %}
</carousel-block>

{% stylesheet %}
  .carousel-block {
    display: flex;
    align-items: center;
    gap: var(--gap-xs, 0.75rem);
    width: 100%;
    position: relative;
  }

  .carousel-block .swiper {
    width: 100%;
    overflow: hidden;
  }

  .carousel-block__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 1px solid rgb(var(--color-border));
    border-radius: 50%;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    cursor: pointer;
    z-index: var(--layer-raised, 2);
  }

  .carousel-block__arrow:hover {
    background: rgb(var(--color-foreground) / 0.05);
  }

  .carousel-block__arrow:focus-visible {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  .carousel-block__arrow svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .carousel-block {
      margin-block-end: var(--carousel-mb-mobile, 0px);
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .carousel-block {
      margin-block-end: var(--carousel-mb-tablet, 0px);
    }
  }

  @media screen and (min-width: 990px) {
    .carousel-block {
      margin-block-end: var(--carousel-mb-desktop, 0px);
    }
  }

  .carousel-block .swiper-wrapper {
    align-items: stretch;
  }

  .carousel-block .swiper-slide {
    height: auto;
    display: flex;
    flex-direction: column;
  }

  .carousel-block .swiper-slide > * {
    flex: 1;
    min-height: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.carousel_block",
  "tag": null,
  "blocks": [
    {
      "type": "_carousel-slide"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "t:settings.slides_per_view_mobile",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 1
    },
    {
