      "label": "t:settings.autoplay_mobile",
      "default": false
    },
    {
      "type": "number",
      "id": "autoplay_delay_mobile",
      "label": "t:settings.autoplay_delay_mobile",
      "default": 5,
      "visible_if": "{{ block.settings.autoplay_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows_mobile",
      "label": "t:settings.show_arrows_mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "external_arrows_mobile",
      "label": "t:settings.external_arrows_mobile",
      "default": false,
      "visible_if": "{{ block.settings.show_arrows_mobile }}"
    },
    {
      "type": "checkbox",
      "id": "show_dots_mobile",
      "label": "t:settings.show_dots_mobile",
      "default": true
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "label": "t:settings.margin_bottom_mobile",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.tablet"
    },
    {
      "type": "range",
      "id": "slides_per_view_tablet",
      "label": "t:settings.slides_per_view_tablet",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 2
    },
    {
      "type": "number",
      "id": "slide_gap_tablet",
      "label": "t:settings.slide_gap_tablet",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "autoplay_tablet",
      "label": "t:settings.autoplay_tablet",
      "default": false
    },
    {
      "type": "number",
      "id": "autoplay_delay_tablet",
      "label": "t:settings.autoplay_delay_tablet",
      "default": 5,
      "visible_if": "{{ block.settings.autoplay_tablet }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows_tablet",
      "label": "t:settings.show_arrows_tablet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "external_arrows_tablet",
      "label": "t:settings.external_arrows_tablet",
      "default": false,
      "visible_if": "{{ block.settings.show_arrows_tablet }}"
    },
    {
      "type": "checkbox",
      "id": "show_dots_tablet",
      "label": "t:settings.show_dots_tablet",
      "default": true
    },
    {
      "type": "number",
      "id": "margin_bottom_tablet",
      "label": "t:settings.margin_bottom_tablet",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.desktop"
    },
    {
      "type": "range",
      "id": "slides_per_view_desktop",
      "label": "t:settings.slides_per_view_desktop",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 3
    },
    {
      "type": "number",
      "id": "slide_gap_desktop",
      "label": "t:settings.slide_gap_desktop",
