      "id": "autoplay_delay_desktop",
      "label": "t:settings.autoplay_delay_desktop",
      "default": 5,
      "visible_if": "{{ block.settings.autoplay_desktop }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows_desktop",
      "label": "t:settings.show_arrows_desktop",
