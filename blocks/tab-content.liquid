{% doc %}
  Tab Content Block

  Renders a container that is shown/hidden based on the active tab
  navigation selection. Accepts nested blocks via content_for 'blocks'.
  Links to a tab navigation block via matching group_id and target_id.

  @example
  {% content_for 'block', type: 'tab-content', id: 'tab-content-1' %}
{% enddoc %}

{% comment %}
  == AI DOCUMENTATION ==

  ▸ PURPOSE
  Tab panel container that is shown or hidden based on the active tab
  navigation selection. Hidden by default (display:none), becomes visible
  when tab-system.js adds the .tab-content--active class.

  ▸ CONTEXT
  - Parent: any container that accepts @theme blocks (generic-section,
    _grid-column, group, etc.) — placed as a sibling of the tab-navigation
    group block
  - Children: any @theme or @app blocks (text, button, image, grid-row,
    carousel-block, hero-block, etc.)
  - MUST be paired with a tab-navigation block sharing the same group_id
    and target_id
  - JS: assets/tab-system.js listens for tab clicks and toggles
    .tab-content--active on matching panels

  ▸ KEY SCHEMA SETTINGS
  - group_id (text): identifies which tab group this panel belongs to (default: "tabs-1")
  - target_id (text): matches the target_id of the tab-navigation button (default: "tab-1")

  ▸ USAGE EXAMPLES
  Template JSON — tab panel with nested content:
    {
      "type": "tab-content",
      "settings": { "group_id": "product-tabs", "target_id": "details" },
      "blocks": {
        "desc_A1b2C3": {
          "type": "text",
          "settings": { "text": "<p>Product details content goes here.</p>" }
        }
      },
      "block_order": ["desc_A1b2C3"]
    }

  Full tab system structure (inside a generic-section):
    generic-section
      ├── group (horizontal, acts as tab bar)
      │   ├── tab-navigation { group_id: "tabs-1", target_id: "tab-1", is_active: true }
      │   └── tab-navigation { group_id: "tabs-1", target_id: "tab-2" }
      ├── tab-content { group_id: "tabs-1", target_id: "tab-1" }
      │   └── text / button / image / ...
      └── tab-content { group_id: "tabs-1", target_id: "tab-2" }
          └── text / button / image / ...
{% endcomment %}

<div
  {{ block.shopify_attributes }}
  class="tab-content"
  role="tabpanel"
  data-tab-content
  data-tab-group="{{ block.settings.group_id }}"
  data-tab-id="{{ block.settings.target_id }}"
>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
.tab-content {
  display: none;
}

.tab-content--active {
  display: block;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.tab_content",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.tab_settings"
    },
    {
      "type": "text",
      "id": "group_id",
      "label": "t:settings.group_id",
      "info": "t:settings.group_id_info",
      "default": "tabs-1"
    },
    {
      "type": "text",
      "id": "target_id",
      "label": "t:settings.target_id",
      "info": "t:settings.target_id_info",
      "default": "tab-1"
    }
  ],
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "t:names.tab_content",
      "category": "t:categories.layout"
    }
  ]
}
{% endschema %}
