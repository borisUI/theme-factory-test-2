{% doc %}
  Video Testimonial Block

  Renders a circular video thumbnail with play button, alongside quote text and attribution.
  Clicking the play button opens a fullscreen video modal.

  @example
  {% content_for 'block', type: 'video-testimonial', id: 'review-1' %}
{% enddoc %}

<video-testimonial
  {{ block.shopify_attributes }}
  class="video-testimonial"
  data-video-url="{{ block.settings.video_url }}"
  style="
    --vt-quote-color: {{ block.settings.quote_color }};
    --vt-attribution-color: {{ block.settings.attribution_color }};
    --vt-divider-color: {{ block.settings.divider_color }};
    --vt-mb-mobile: {{ block.settings.margin_bottom_mobile | default: 0 }}px;
    --vt-mb-desktop: {{ block.settings.margin_bottom_desktop | default: 0 }}px;
  "
>
  <div class="video-testimonial__media">
    {% if block.settings.thumbnail_image %}
      <img
        class="video-testimonial__thumb"
        src="{{ block.settings.thumbnail_image | image_url: width: 216 }}"
        alt="{{ block.settings.attribution_text | escape }}"
        width="108"
        height="108"
        loading="lazy"
      />
    {% else %}
      <div class="video-testimonial__thumb-placeholder"></div>
    {% endif %}
    <button class="video-testimonial__play-btn" type="button" aria-label="Play video testimonial">
      <img src="{{ 'play.svg' | asset_url }}" alt="" width="32" height="32" aria-hidden="true" />
    </button>
  </div>
  <div class="video-testimonial__content">
    {% if block.settings.quote_text != blank %}
      <p class="video-testimonial__quote">{{ block.settings.quote_text | escape }}</p>
    {% endif %}
    <span class="video-testimonial__divider"></span>
    {% if block.settings.attribution_text != blank %}
      <p class="video-testimonial__attribution">{{ block.settings.attribution_text | escape }}</p>
    {% endif %}
  </div>
</video-testimonial>

<script src="{{ 'video-testimonial.js' | asset_url }}" type="module" defer></script>

{% stylesheet %}
.video-testimonial {
  display: flex;
  flex-direction: row;
  gap: 16px;
  align-items: flex-start;
  padding-inline-end: 8px;
  margin-block-end: var(--vt-mb-desktop);
}

@media screen and (max-width: 749px) {
  .video-testimonial {
    margin-block-end: var(--vt-mb-mobile);
  }
}

.video-testimonial__media {
  position: relative;
  flex-shrink: 0;
  width: 108px;
  height: 108px;
  border-radius: 50%;
  overflow: hidden;
}

.video-testimonial__thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 50%;
}

.video-testimonial__thumb-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #D9D9D9;
}

.video-testimonial__play-btn {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
}

.video-testimonial__play-btn:focus-visible {
  outline: 2px solid #FFFFFF;
  outline-offset: 2px;
  border-radius: 50%;
}

.video-testimonial__content {
  display: flex;
  flex-direction: column;
  gap: 12px;
  justify-content: space-between;
  min-height: 108px;
}

.video-testimonial__quote {
  font-family: var(--font-heading--family);
  font-weight: 500;
  font-size: 16px;
  line-height: 24px;
  color: var(--vt-quote-color, #FFFFFF);
  margin: 0;
}

.video-testimonial__divider {
  display: block;
  width: 32px;
  height: 1px;
  background-color: var(--vt-divider-color, #B5B5A0);
}

.video-testimonial__attribution {
  font-family: var(--font-body--family);
  font-weight: 400;
  font-size: 14px;
  line-height: 20px;
  color: var(--vt-attribution-color, #B5B5A0);
  margin: 0;
}

.video-testimonial__modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-testimonial__modal-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
}

.video-testimonial__modal-content {
  position: relative;
  width: 90vw;
  max-width: 900px;
  z-index: 1;
}

.video-testimonial__modal-close {
  position: absolute;
  top: -40px;
  right: 0;
  background: none;
  border: none;
  color: #FFFFFF;
  font-size: 32px;
  cursor: pointer;
  line-height: 1;
  padding: 4px 8px;
}

.video-testimonial__modal-close:focus-visible {
  outline: 2px solid #FFFFFF;
  outline-offset: 2px;
}

.video-testimonial__modal-video {
  width: 100%;
  border-radius: 8px;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.video_testimonial",
  "tag": null,
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "t:settings.video_url"
    },
    {
      "type": "image_picker",
      "id": "thumbnail_image",
      "label": "t:settings.thumbnail_image"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "t:settings.quote_text"
    },
    {
      "type": "text",
      "id": "attribution_text",
      "label": "t:settings.attribution_text"
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "t:settings.quote_color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "attribution_color",
      "label": "t:settings.attribution_color",
      "default": "#B5B5A0"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "t:settings.divider_color",
      "default": "#B5B5A0"
    },
    {
      "type": "header",
      "content": "t:content.margin"
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "label": "t:settings.margin_bottom_mobile",
      "default": 0
    },
    {
      "type": "number",
      "id": "margin_bottom_desktop",
      "label": "t:settings.margin_bottom_desktop",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.video_testimonial",
      "category": "t:categories.interactive"
    }
  ]
}
{% endschema %}
