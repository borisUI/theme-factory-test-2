{% doc %}
  Grid Row Block

  A 12-column CSS grid container that only accepts _grid-column children.

  @example
  {% content_for 'block', type: 'grid-row', id: 'row-1' %}
{% enddoc %}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<div
  class="grid-row"
  style="
    --grid-row-col-gap-mobile: {{ block.settings.column_gap_mobile }}px;
    --grid-row-col-gap-tablet: {{ block.settings.column_gap_tablet }}px;
    --grid-row-col-gap-desktop: {{ block.settings.column_gap_desktop }}px;
    --grid-row-row-gap-mobile: {{ block.settings.row_gap_mobile }}px;
    --grid-row-row-gap-tablet: {{ block.settings.row_gap_tablet }}px;
    --grid-row-row-gap-desktop: {{ block.settings.row_gap_desktop }}px;
    --grid-row-align-mobile: {{ block.settings.vertical_alignment_mobile }};
    --grid-row-align-tablet: {{ block.settings.vertical_alignment_tablet }};
    --grid-row-align-desktop: {{ block.settings.vertical_alignment_desktop }};
    --grid-row-mb-mobile: {{ block.settings.margin_bottom_mobile }}px;
    --grid-row-mb-tablet: {{ block.settings.margin_bottom_tablet }}px;
    --grid-row-mb-desktop: {{ block.settings.margin_bottom_desktop }}px;
  "
  {{ block.shopify_attributes }}
>
  {{- children -}}
</div>

{% stylesheet %}
  .grid-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .grid-row {
      column-gap: var(--grid-row-col-gap-mobile, 16px);
      row-gap: var(--grid-row-row-gap-mobile, 16px);
      align-items: var(--grid-row-align-mobile, start);
      margin-block-end: var(--grid-row-mb-mobile, 0px);
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .grid-row {
      column-gap: var(--grid-row-col-gap-tablet, 20px);
      row-gap: var(--grid-row-row-gap-tablet, 20px);
      align-items: var(--grid-row-align-tablet, start);
      margin-block-end: var(--grid-row-mb-tablet, 0px);
    }
  }

  @media screen and (min-width: 990px) {
    .grid-row {
      column-gap: var(--grid-row-col-gap-desktop, 24px);
      row-gap: var(--grid-row-row-gap-desktop, 24px);
      align-items: var(--grid-row-align-desktop, start);
      margin-block-end: var(--grid-row-mb-desktop, 0px);
    }
  }
{% endstylesheet %}

