{% doc %}
  Grid Row Block

  A 12-column CSS grid container that only accepts _grid-column children.

  @example
  {% content_for 'block', type: 'grid-row', id: 'row-1' %}
{% enddoc %}

{% comment %}
  == AI DOCUMENTATION ==

  ▸ PURPOSE
  12-column CSS grid container. Provides responsive column-gap, row-gap,
  vertical alignment, and margin-bottom across three breakpoints
  (mobile <750px, tablet 750-989px, desktop >=990px).

  ▸ CONTEXT
  - Parent: any container that accepts @theme blocks (generic-section,
    hero-block, tab-content, _grid-column for nested grids, etc.)
  - Children: ONLY _grid-column blocks (schema restricts to type: _grid-column)
  - Each _grid-column child specifies how many of the 12 columns it spans

  ▸ KEY SCHEMA SETTINGS
  Per breakpoint (mobile / tablet / desktop):
  - vertical_alignment_{bp} (select): start | center | end | stretch
  - column_gap_{bp} (number, px): gap between columns
  - row_gap_{bp} (number, px): gap between rows when columns wrap
  - margin_bottom_{bp} (number, px): space below the grid row

  ▸ USAGE EXAMPLES
  Template JSON — 2-column layout (50/50 desktop, stacked mobile):
    {
      "type": "grid-row",
      "settings": {
        "column_gap_desktop": 24,
        "row_gap_mobile": 16,
        "vertical_alignment_desktop": "center"
      },
      "blocks": {
        "col_left_A1b2C3": {
          "type": "_grid-column",
          "settings": { "column_span_mobile": "12", "column_span_tablet": "6", "column_span_desktop": "6" },
          "blocks": { "text_D4e5F6": { "type": "text", "settings": { "text": "<h2>Left Column</h2>" } } },
          "block_order": ["text_D4e5F6"]
        },
        "col_right_G7h8I9": {
          "type": "_grid-column",
          "settings": { "column_span_mobile": "12", "column_span_tablet": "6", "column_span_desktop": "6" },
          "blocks": { "text_J0k1L2": { "type": "text", "settings": { "text": "<p>Right column content</p>" } } },
          "block_order": ["text_J0k1L2"]
        }
      },
      "block_order": ["col_left_A1b2C3", "col_right_G7h8I9"]
    }

  Template JSON — 3-column layout (4/4/4 desktop, stacked mobile):
    {
      "type": "grid-row",
      "settings": { "column_gap_desktop": 24 },
      "blocks": {
        "col1_M3n4O5": { "type": "_grid-column", "settings": { "column_span_mobile": "12", "column_span_desktop": "4" } },
        "col2_P6q7R8": { "type": "_grid-column", "settings": { "column_span_mobile": "12", "column_span_desktop": "4" } },
        "col3_S9t0U1": { "type": "_grid-column", "settings": { "column_span_mobile": "12", "column_span_desktop": "4" } }
      },
      "block_order": ["col1_M3n4O5", "col2_P6q7R8", "col3_S9t0U1"]
    }
{% endcomment %}

{%- capture children -%}
  {% content_for 'blocks' %}
{%- endcapture -%}

<div
  class="grid-row"
  style="
    --grid-row-col-gap-mobile: {{ block.settings.column_gap_mobile }}px;
    --grid-row-col-gap-tablet: {{ block.settings.column_gap_tablet }}px;
    --grid-row-col-gap-desktop: {{ block.settings.column_gap_desktop }}px;
    --grid-row-row-gap-mobile: {{ block.settings.row_gap_mobile }}px;
    --grid-row-row-gap-tablet: {{ block.settings.row_gap_tablet }}px;
    --grid-row-row-gap-desktop: {{ block.settings.row_gap_desktop }}px;
    --grid-row-align-mobile: {{ block.settings.vertical_alignment_mobile }};
    --grid-row-align-tablet: {{ block.settings.vertical_alignment_tablet }};
    --grid-row-align-desktop: {{ block.settings.vertical_alignment_desktop }};
    --grid-row-mb-mobile: {{ block.settings.margin_bottom_mobile }}px;
    --grid-row-mb-tablet: {{ block.settings.margin_bottom_tablet }}px;
    --grid-row-mb-desktop: {{ block.settings.margin_bottom_desktop }}px;
  "
  {{ block.shopify_attributes }}
>
  {{- children -}}
</div>

{% stylesheet %}
  .grid-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .grid-row {
      column-gap: var(--grid-row-col-gap-mobile, 16px);
      row-gap: var(--grid-row-row-gap-mobile, 16px);
      align-items: var(--grid-row-align-mobile, start);
      margin-block-end: var(--grid-row-mb-mobile, 0px);
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .grid-row {
      column-gap: var(--grid-row-col-gap-tablet, 20px);
      row-gap: var(--grid-row-row-gap-tablet, 20px);
      align-items: var(--grid-row-align-tablet, start);
      margin-block-end: var(--grid-row-mb-tablet, 0px);
    }
  }

  @media screen and (min-width: 990px) {
    .grid-row {
      column-gap: var(--grid-row-col-gap-desktop, 24px);
      row-gap: var(--grid-row-row-gap-desktop, 24px);
      align-items: var(--grid-row-align-desktop, start);
      margin-block-end: var(--grid-row-mb-desktop, 0px);
    }
  }
{% endstylesheet %}

