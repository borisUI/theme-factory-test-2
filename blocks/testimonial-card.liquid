{% doc %}
  Testimonial Card Block

  Renders a card with an image, title, description, and name + role attribution
  at the bottom. Used for dietitian or expert testimonials.

  @example
  {% content_for 'block', type: 'testimonial-card', id: 'testimonial-1' %}
{% enddoc %}

<div
  {{ block.shopify_attributes }}
  class="testimonial-card"
  style="
    --tc-bg: {{ block.settings.bg_color }};
    --tc-text: {{ block.settings.text_color }};
    --tc-mb-mobile: {{ block.settings.margin_bottom_mobile | default: 0 }}px;
    --tc-mb-desktop: {{ block.settings.margin_bottom_desktop | default: 0 }}px;
  "
>
  {% if block.settings.image %}
    <div class="testimonial-card__image-wrapper">
      <img
        class="testimonial-card__image"
        src="{{ block.settings.image | image_url: width: 600 }}"
        alt="{{ block.settings.testimonial_name | default: block.settings.testimonial_title | escape }}"
        width="300"
        height="300"
        loading="lazy"
      />
    </div>
  {% endif %}

  <div class="testimonial-card__content">
    {% if block.settings.testimonial_title != blank %}
      <h3 class="testimonial-card__title">{{ block.settings.testimonial_title | escape }}</h3>
    {% endif %}

    {% if block.settings.testimonial_description != blank %}
      <p class="testimonial-card__description">{{ block.settings.testimonial_description | escape }}</p>
    {% endif %}

    {% if block.settings.testimonial_name != blank or block.settings.testimonial_role != blank %}
      <div class="testimonial-card__attribution">
        {% if block.settings.testimonial_name != blank %}
          <span class="testimonial-card__name">{{ block.settings.testimonial_name | escape }}</span>
        {% endif %}
        {% if block.settings.testimonial_role != blank %}
          <span class="testimonial-card__role">{{ block.settings.testimonial_role | escape }}</span>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
.testimonial-card {
  display: flex;
  flex-direction: column;
  border-radius: 8px;
  overflow: hidden;
  background-color: var(--tc-bg, #FFFFFF);
  color: var(--tc-text, #141414);
  margin-block-end: var(--tc-mb-desktop);
}

@media screen and (max-width: 749px) {
  .testimonial-card {
    margin-block-end: var(--tc-mb-mobile);
  }
}

.testimonial-card__image-wrapper {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
}

.testimonial-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.testimonial-card__content {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 20px 16px;
  flex-grow: 1;
}

.testimonial-card__title {
  font-family: var(--font-heading--family);
  font-size: 20px;
  font-weight: 600;
  line-height: 28px;
  margin: 0;
}

.testimonial-card__description {
  font-family: var(--font-body--family);
  font-size: 16px;
  line-height: 24px;
  margin: 0;
  opacity: 0.8;
  flex-grow: 1;
}

.testimonial-card__attribution {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-block-start: 8px;
  padding-block-start: 12px;
  border-block-start: 1px solid currentColor;
  opacity: 0.6;
}

.testimonial-card__name {
  font-family: var(--font-body--family);
  font-size: 14px;
  font-weight: 600;
  line-height: 20px;
}

.testimonial-card__role {
  font-family: var(--font-body--family);
  font-size: 12px;
  line-height: 16px;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.testimonial_card",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "text",
      "id": "testimonial_title",
      "label": "t:settings.testimonial_title"
    },
    {
      "type": "textarea",
      "id": "testimonial_description",
      "label": "t:settings.testimonial_description"
    },
    {
      "type": "text",
      "id": "testimonial_name",
      "label": "t:settings.testimonial_name"
    },
    {
      "type": "text",
      "id": "testimonial_role",
      "label": "t:settings.testimonial_role"
    },
    {
      "type": "header",
      "content": "t:content.colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:settings.bg_color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "t:content.margin"
    },
    {
      "type": "number",
      "id": "margin_bottom_mobile",
      "label": "t:settings.margin_bottom_mobile",
      "default": 0
    },
    {
      "type": "number",
      "id": "margin_bottom_desktop",
      "label": "t:settings.margin_bottom_desktop",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.testimonial_card",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
