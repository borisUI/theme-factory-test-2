{% doc %}
  Custom Button Block

  Renders a styled anchor element as a button with fully responsive
  typography, sizing, padding, colors, and border settings.

  @example
  {% content_for 'block', type: 'custom-button', id: 'cta-button' %}
{% enddoc %}

{% liquid
  assign bg_is_transparent = false
  if block.settings.background_color == blank or block.settings.background_color == 'transparent' or block.settings.background_color contains 'rgba'
    assign bg_is_transparent = true
  endif

  if bg_is_transparent
    assign hover_r = block.settings.text_color | color_extract: 'red'
    assign hover_g = block.settings.text_color | color_extract: 'green'
    assign hover_b = block.settings.text_color | color_extract: 'blue'
  endif
%}

<a
  {{ block.shopify_attributes }}
  class="custom-button{% if bg_is_transparent %} custom-button--transparent-bg{% endif %}"
  {% if block.settings.link != blank %}
    href="{{ block.settings.link }}"
  {% endif %}
  {% if block.settings.open_in_new_tab %}
    target="_blank"
    rel="noopener noreferrer"
  {% endif %}
  style="
    --custom-button-font-family: {{ block.settings.font_desktop }};
    --custom-button-font-size: {{ block.settings.font_size_desktop }};
    --custom-button-font-weight: {{ block.settings.font_weight_desktop }};
    --custom-button-line-height: {{ block.settings.line_height_desktop }};
    --custom-button-letter-spacing: {{ block.settings.letter_spacing_desktop }}px;
    --custom-button-text-transform: {{ block.settings.case_desktop }};
    --custom-button-font-family-mobile: {{ block.settings.font_mobile }};
    --custom-button-font-size-mobile: {{ block.settings.font_size_mobile }};
    --custom-button-font-weight-mobile: {{ block.settings.font_weight_mobile }};
    --custom-button-line-height-mobile: {{ block.settings.line_height_mobile }};
    --custom-button-letter-spacing-mobile: {{ block.settings.letter_spacing_mobile }}px;
    --custom-button-text-transform-mobile: {{ block.settings.case_mobile }};
    --custom-button-bg-color: {{ block.settings.background_color }};
    --custom-button-text-color: {{ block.settings.text_color }};
    --custom-button-min-width-desktop: {{ block.settings.min_width_desktop }}px;
    --custom-button-min-width-mobile: {{ block.settings.min_width_mobile }}px;
    --custom-button-width-desktop: {% if block.settings.width_desktop == 'full_width' %}100%{% else %}auto{% endif %};
    --custom-button-width-mobile: {% if block.settings.width_mobile == 'full_width' %}100%{% else %}auto{% endif %};
    --custom-button-padding-top-desktop: {{ block.settings.padding_top_desktop }}px;
    --custom-button-padding-bottom-desktop: {{ block.settings.padding_bottom_desktop }}px;
    --custom-button-padding-left-desktop: {{ block.settings.padding_left_desktop }}px;
    --custom-button-padding-right-desktop: {{ block.settings.padding_right_desktop }}px;
    --custom-button-padding-top-mobile: {{ block.settings.padding_top_mobile }}px;
    --custom-button-padding-bottom-mobile: {{ block.settings.padding_bottom_mobile }}px;
    --custom-button-padding-left-mobile: {{ block.settings.padding_left_mobile }}px;
    --custom-button-padding-right-mobile: {{ block.settings.padding_right_mobile }}px;
    --custom-button-border-radius: {{ block.settings.border_radius }}px;
    --custom-button-border-color: {{ block.settings.border_color }};
    --custom-button-border-width: {{ block.settings.border_width }}px;
    {% if bg_is_transparent %}--custom-button-hover-bg: rgba({{ hover_r }}, {{ hover_g }}, {{ hover_b }}, 0.18);{% endif %}
  "
>
  {{ block.settings.label | escape }}
</a>

{% stylesheet %}
.custom-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-decoration: none;
  cursor: pointer;

  font-family: var(--custom-button-font-family);
  font-size: var(--custom-button-font-size);
  font-weight: var(--custom-button-font-weight);
  line-height: var(--custom-button-line-height);
  letter-spacing: var(--custom-button-letter-spacing);
  text-transform: var(--custom-button-text-transform);

  background-color: var(--custom-button-bg-color);
  color: var(--custom-button-text-color);

  min-width: var(--custom-button-min-width-desktop);
  width: var(--custom-button-width-desktop);

  padding-block-start: var(--custom-button-padding-top-desktop);
  padding-block-end: var(--custom-button-padding-bottom-desktop);
  padding-inline-start: var(--custom-button-padding-left-desktop);
  padding-inline-end: var(--custom-button-padding-right-desktop);

  border-radius: var(--custom-button-border-radius);
  border-color: var(--custom-button-border-color);
  border-width: var(--custom-button-border-width);
  border-style: solid;
  transition: background-color 150ms, color 150ms;
}

.custom-button:hover {
  background-color: var(--custom-button-text-color);
  color: var(--custom-button-bg-color);
}

.custom-button--transparent-bg:hover {
  background-color: var(--custom-button-hover-bg);
  color: var(--custom-button-text-color);
}

@media screen and (max-width: 749px) {
  .custom-button {
    font-family: var(--custom-button-font-family-mobile);
    font-size: var(--custom-button-font-size-mobile);
    font-weight: var(--custom-button-font-weight-mobile);
    line-height: var(--custom-button-line-height-mobile);
    letter-spacing: var(--custom-button-letter-spacing-mobile);
    text-transform: var(--custom-button-text-transform-mobile);

    min-width: var(--custom-button-min-width-mobile);
    width: var(--custom-button-width-mobile);

    padding-block-start: var(--custom-button-padding-top-mobile);
    padding-block-end: var(--custom-button-padding-bottom-mobile);
    padding-inline-start: var(--custom-button-padding-left-mobile);
    padding-inline-end: var(--custom-button-padding-right-mobile);
  }
}
{% endstylesheet %}

