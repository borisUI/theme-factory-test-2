{% doc %}
  SHOP.COM Mega Menu

  Renders the off-canvas mega menu drawer with drill-down panels for the SHOP.COM header.
  Must be rendered inside the shopcom-header-component custom element so that
  JS event handlers (on:click) are bound correctly.

  @param {object} section - The parent section object (required)

  @example
  {% render 'shopcom-mega-menu', section: section %}
{% enddoc %}

{% liquid
  assign section = section | default: empty
  unless section != empty
    break
  endunless

  assign shop_menu = section.settings.shop_menu
  assign account_menu = section.settings.account_menu
  assign features_menu = section.settings.features_menu
  assign take_quiz_text = section.settings.take_quiz_text | default: 'Take Quiz'
  assign take_quiz_url = section.settings.take_quiz_url | default: '#'
  assign cashback_text = section.settings.cashback_text | default: 'Get up to 50% Cashback'
  assign cashback_link = section.settings.cashback_link | default: '#'
%}

{%- comment -%} Overlay backdrop {%- endcomment -%}
<div class="shopcom-menu-overlay" ref="menuOverlay" on:click="/handleOverlayClick"></div>

{%- comment -%} Drawer container {%- endcomment -%}
<nav class="shopcom-menu-drawer" ref="menuDrawer" aria-label="{{ 'accessibility.navigation' | t | default: 'Navigation' }}">
  <div class="shopcom-menu-drawer__inner">

    {%- comment -%} ============================================
      PANEL 1: Main Menu
    ============================================ {%- endcomment -%}
    <div class="shopcom-menu-panel is-active" data-menu-panel="main">
      <div class="shopcom-menu-panel__header">
        <span class="shopcom-menu-panel__logo">SHOP.COM</span>
        <button
          type="button"
          class="shopcom-menu-panel__close"
          ref="closeButton"
          on:click="/handleMenuClose"
          aria-label="{{ 'accessibility.close' | t | default: 'Close menu' }}"
        >
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <div class="shopcom-menu-panel__body">
        {%- comment -%} Shop section {%- endcomment -%}
        <div class="shopcom-menu-section">
          <h3 class="shopcom-menu-section__title">Shop</h3>
          <ul class="shopcom-menu-list">
            <li class="shopcom-menu-list__item">
              <button
                type="button"
                class="shopcom-menu-list__link shopcom-menu-list__link--drilldown"
                ref="panelTrigger"
                on:click="/handleDrillDown/shop-by-category"
              >
                <span>Shop by Category</span>
                <span class="shopcom-menu-list__arrow">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
              </button>
            </li>
            <li class="shopcom-menu-list__item">
              <button
                type="button"
                class="shopcom-menu-list__link shopcom-menu-list__link--drilldown"
                ref="panelTrigger"
                on:click="/handleDrillDown/shop-by-brands"
              >
                <span>Shop by Brands</span>
                <span class="shopcom-menu-list__arrow">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
              </button>
            </li>
            {%- if shop_menu != blank -%}
              {%- for link in shop_menu.links -%}
                {%- if link.title == 'Shop by Category' or link.title == 'Shop by Brands' -%}
                  {%- continue -%}
                {%- endif -%}
                <li class="shopcom-menu-list__item">
                  <a href="{{ link.url }}" class="shopcom-menu-list__link">
                    {{ link.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>

        <div class="shopcom-menu-divider"></div>

        {%- comment -%} Account section {%- endcomment -%}
        <div class="shopcom-menu-section">
          <h3 class="shopcom-menu-section__title">Account</h3>
          <ul class="shopcom-menu-list">
            {%- if account_menu != blank -%}
              {%- for link in account_menu.links -%}
                <li class="shopcom-menu-list__item">
                  <a href="{{ link.url }}" class="shopcom-menu-list__link shopcom-menu-list__link--icon">
                    {%- liquid
                      assign icon_name = link.title | handleize
                      if icon_name == 'sign-in' or icon_name == 'create-account' or icon_name == 'my-account'
                        assign icon_name = 'account'
                      elsif icon_name == 'track-my-orders'
                        assign icon_name = 'track-orders'
                      elsif icon_name == 'reorder-favorites'
                        assign icon_name = 'reorder'
                      elsif icon_name == 'help-center'
                        assign icon_name = 'help'
                      endif
                    -%}
                    {% render 'shopcom-menu-icons', icon: icon_name %}
                    <span>{{ link.title | escape }}</span>
                  </a>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>

        <div class="shopcom-menu-divider"></div>

        {%- comment -%} Features section {%- endcomment -%}
        <div class="shopcom-menu-section">
          <h3 class="shopcom-menu-section__title">Features</h3>
          <ul class="shopcom-menu-list">
            {%- if features_menu != blank -%}
              {%- for link in features_menu.links -%}
                <li class="shopcom-menu-list__item">
                  <a href="{{ link.url }}" class="shopcom-menu-list__link shopcom-menu-list__link--icon">
                    {%- liquid
                      assign icon_name = link.title | handleize
                      if icon_name == 'home-shopping-list'
                        assign icon_name = 'shopping-list'
                      elsif icon_name == 'nutri-physical-profile'
                        assign icon_name = 'nutri-physical'
                      endif
                    -%}
                    {% render 'shopcom-menu-icons', icon: icon_name %}
                    <span>{{ link.title | escape }}</span>
                  </a>
                </li>
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </div>
      </div>

      {%- comment -%} Bottom CTA area {%- endcomment -%}
      <div class="shopcom-menu-panel__footer">
        <a href="{{ take_quiz_url }}" class="shopcom-menu-cta">
          {{ take_quiz_text | escape }}
        </a>
        <a href="{{ cashback_link }}" class="shopcom-menu-cashback">
          {{ cashback_text | escape }}
        </a>
      </div>
    </div>

    {%- comment -%} ============================================
      PANEL 2: Shop by Category
    ============================================ {%- endcomment -%}
    <div class="shopcom-menu-panel" data-menu-panel="shop-by-category">
      <div class="shopcom-menu-panel__header shopcom-menu-panel__header--sub">
        <button
          type="button"
          class="shopcom-menu-panel__back"
          ref="backButton"
          on:click="/handleBack"
          aria-label="{{ 'accessibility.back' | t | default: 'Back' }}"
        >
          {{ 'icon-chevron-left.svg' | inline_asset_content }}
        </button>
        <span class="shopcom-menu-panel__title">Shop by Category</span>
        <button
          type="button"
          class="shopcom-menu-panel__close"
          ref="closeButton"
          on:click="/handleMenuClose"
          aria-label="{{ 'accessibility.close' | t | default: 'Close menu' }}"
        >
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <div class="shopcom-menu-panel__body">
        <ul class="shopcom-menu-list">
          {%- if shop_menu != blank -%}
            {%- for link in shop_menu.links -%}
              {%- if link.title == 'Shop by Category' -%}
                {%- for child in link.links -%}
                  <li class="shopcom-menu-list__item">
                    {%- if child.links.size > 0 -%}
                      <button
                        type="button"
                        class="shopcom-menu-list__link shopcom-menu-list__link--drilldown"
                        ref="panelTrigger"
                        on:click="/handleSubCategory/{{ child.title | handleize }}/{{ child.title | escape }}"
                      >
                        <span>{{ child.title | escape }}</span>
                        <span class="shopcom-menu-list__arrow">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
                      </button>
                    {%- else -%}
                      <a href="{{ child.url }}" class="shopcom-menu-list__link">
                        {{ child.title | escape }}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ============================================
      PANEL 3: Shop by Brands
    ============================================ {%- endcomment -%}
    <div class="shopcom-menu-panel" data-menu-panel="shop-by-brands">
      <div class="shopcom-menu-panel__header shopcom-menu-panel__header--sub">
        <button
          type="button"
          class="shopcom-menu-panel__back"
          ref="backButton"
          on:click="/handleBack"
          aria-label="{{ 'accessibility.back' | t | default: 'Back' }}"
        >
          {{ 'icon-chevron-left.svg' | inline_asset_content }}
        </button>
        <span class="shopcom-menu-panel__title">Shop by Brands</span>
        <button
          type="button"
          class="shopcom-menu-panel__close"
          ref="closeButton"
          on:click="/handleMenuClose"
          aria-label="{{ 'accessibility.close' | t | default: 'Close menu' }}"
        >
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <div class="shopcom-menu-panel__body">
        <a href="/collections/vendors" class="shopcom-menu-brands__shop-all">Shop All Brands</a>

        {%- comment -%} Brand accordion sections from section blocks {%- endcomment -%}
        {%- assign current_category = '' -%}
        {%- assign accordion_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand-logo' -%}
            {%- assign brand_category = block.settings.brand_category | default: 'Other' -%}
            {%- if brand_category != current_category -%}
              {%- if current_category != '' -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
              {%- assign current_category = brand_category -%}
              {%- assign accordion_index = accordion_index | plus: 1 -%}
              <div class="shopcom-menu-brands__accordion">
                <button
                  type="button"
                  class="shopcom-menu-brands__accordion-toggle"
                  ref="accordionToggle"
                  on:click="/handleAccordionToggle"
                  aria-expanded="false"
                  aria-controls="BrandsAccordion-{{ section.id }}-{{ accordion_index }}"
                >
                  <span>{{ brand_category | escape }}</span>
                  <span class="shopcom-menu-brands__accordion-icon">
                    {{ 'icon-plus.svg' | inline_asset_content }}
                  </span>
                </button>
                <div
                  class="shopcom-menu-brands__accordion-content"
                  id="BrandsAccordion-{{ section.id }}-{{ accordion_index }}"
                  hidden
                >
                  <div class="shopcom-menu-brands__grid">
            {%- endif -%}

            <a href="{{ block.settings.brand_url | default: '#' }}" class="shopcom-menu-brands__item" {{ block.shopify_attributes }}>
              {%- if block.settings.brand_image != blank -%}
                <div class="shopcom-menu-brands__logo">
                  {{
                    block.settings.brand_image
                    | image_url: width: 80
                    | image_tag:
                      widths: '60,80,120',
                      sizes: '60px',
                      loading: 'lazy',
                      alt: block.settings.brand_name
                  }}
                </div>
              {%- else -%}
                <div class="shopcom-menu-brands__logo shopcom-menu-brands__logo--placeholder">
                  <span>{{ block.settings.brand_name | default: 'Brand' | truncate: 2, '' | upcase }}</span>
                </div>
              {%- endif -%}
              <span class="shopcom-menu-brands__name">{{ block.settings.brand_name | default: 'Brand' | escape }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}

        {%- if current_category != '' -%}
                  </div>
                </div>
              </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ============================================
      PANEL 4: Sub-category (dynamic)
    ============================================ {%- endcomment -%}
    <div class="shopcom-menu-panel" data-menu-panel="sub-category">
      <div class="shopcom-menu-panel__header shopcom-menu-panel__header--sub">
        <button
          type="button"
          class="shopcom-menu-panel__back"
          ref="backButton"
          on:click="/handleBack"
          aria-label="{{ 'accessibility.back' | t | default: 'Back' }}"
        >
          {{ 'icon-chevron-left.svg' | inline_asset_content }}
        </button>
        <span class="shopcom-menu-panel__title" data-subcategory-title>Category</span>
        <button
          type="button"
          class="shopcom-menu-panel__close"
          ref="closeButton"
          on:click="/handleMenuClose"
          aria-label="{{ 'accessibility.close' | t | default: 'Close menu' }}"
        >
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <div class="shopcom-menu-panel__body" data-subcategory-links>
        {%- comment -%} Pre-render all sub-category link sets, JS shows matching one {%- endcomment -%}
        {%- if shop_menu != blank -%}
          {%- for link in shop_menu.links -%}
            {%- if link.title == 'Shop by Category' -%}
              {%- for child in link.links -%}
                {%- if child.links.size > 0 -%}
                  <ul class="shopcom-menu-list" data-parent-handle="{{ child.title | handleize }}" hidden>
                    {%- for grandchild in child.links -%}
                      <li class="shopcom-menu-list__item">
                        <a href="{{ grandchild.url }}" class="shopcom-menu-list__link">
                          {{ grandchild.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              {%- endfor -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</nav>

<style>
  /* ----------------------------------------------------------------
   * Overlay
   * ---------------------------------------------------------------- */
  .shopcom-menu-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 99;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    pointer-events: none;
  }

  .shopcom-menu-overlay.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* ----------------------------------------------------------------
   * Drawer
   * ---------------------------------------------------------------- */
  .shopcom-menu-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    max-width: 350px;
    height: 100dvh;
    background: #ffffff;
    z-index: 100;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .shopcom-menu-drawer.is-open {
    transform: translateX(0);
  }

  .shopcom-menu-drawer__inner {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* ----------------------------------------------------------------
   * Panel system
   * ---------------------------------------------------------------- */
  .shopcom-menu-panel {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    visibility: hidden;
  }

  .shopcom-menu-panel.is-active {
    transform: translateX(0);
    visibility: visible;
  }

  .shopcom-menu-panel.is-hidden-left {
    transform: translateX(-100%);
    visibility: hidden;
  }

  /* ----------------------------------------------------------------
   * Panel header
   * ---------------------------------------------------------------- */
  .shopcom-menu-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #E5E5E5;
    min-height: 56px;
    flex-shrink: 0;
  }

  .shopcom-menu-panel__header--sub {
    gap: 12px;
  }

  .shopcom-menu-panel__logo {
    font-family: var(--font-heading--family, 'DM Sans', sans-serif);
    font-size: 18px;
    font-weight: 700;
    color: #141414;
    letter-spacing: -0.01em;
  }

  .shopcom-menu-panel__title {
    flex: 1;
    font-family: var(--font-heading--family, 'DM Sans', sans-serif);
    font-size: 16px;
    font-weight: 600;
    color: #141414;
  }

  .shopcom-menu-panel__back,
  .shopcom-menu-panel__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    color: #141414;
    flex-shrink: 0;
  }

  .shopcom-menu-panel__back svg,
  .shopcom-menu-panel__close svg {
    width: 20px;
    height: 20px;
  }

  .shopcom-menu-panel__back:focus-visible,
  .shopcom-menu-panel__close:focus-visible {
    outline: 2px solid rgb(var(--color-focus, 32, 125, 148));
    outline-offset: 2px;
  }

  /* ----------------------------------------------------------------
   * Panel body
   * ---------------------------------------------------------------- */
  .shopcom-menu-panel__body {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
  }

  /* ----------------------------------------------------------------
   * Menu sections & dividers
   * ---------------------------------------------------------------- */
  .shopcom-menu-section {
    padding: 8px 20px;
  }

  .shopcom-menu-section__title {
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888888;
    margin: 0 0 4px;
    padding: 0;
  }

  .shopcom-menu-divider {
    height: 1px;
    background: #E5E5E5;
    margin: 4px 20px;
  }

  /* ----------------------------------------------------------------
   * Menu list items
   * ---------------------------------------------------------------- */
  .shopcom-menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .shopcom-menu-list__item {
    margin: 0;
  }

  .shopcom-menu-list__link {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 10px 20px;
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 400;
    color: #141414;
    text-decoration: none;
    border: none;
    background: transparent;
    cursor: pointer;
    text-align: start;
    transition: background-color 0.15s ease;
  }

  .shopcom-menu-list__link:hover {
    background-color: #F5F5F5;
  }

  .shopcom-menu-list__link:focus-visible {
    outline: 2px solid rgb(var(--color-focus, 32, 125, 148));
    outline-offset: -2px;
  }

  .shopcom-menu-list__link--drilldown {
    justify-content: space-between;
  }

  .shopcom-menu-list__link--icon .shopcom-menu-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: #555555;
  }

  .shopcom-menu-list__arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: #999999;
  }

  .shopcom-menu-list__arrow svg {
    width: 16px;
    height: 16px;
  }

  /* ----------------------------------------------------------------
   * Panel footer (CTA)
   * ---------------------------------------------------------------- */
  .shopcom-menu-panel__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    border-top: 1px solid #E5E5E5;
    flex-shrink: 0;
  }

  .shopcom-menu-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 12px 24px;
    background: #207D94;
    color: #ffffff;
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 6px;
    transition: background-color 0.15s ease;
  }

  .shopcom-menu-cta:hover {
    background: #1a6578;
  }

  .shopcom-menu-cta:focus-visible {
    outline: 2px solid rgb(var(--color-focus, 32, 125, 148));
    outline-offset: 2px;
  }

  .shopcom-menu-cashback {
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 13px;
    font-weight: 400;
    color: #207D94;
    text-decoration: none;
  }

  .shopcom-menu-cashback:hover {
    text-decoration: underline;
  }

  /* ----------------------------------------------------------------
   * Brands: Shop All link
   * ---------------------------------------------------------------- */
  .shopcom-menu-brands__shop-all {
    display: block;
    padding: 12px 20px;
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 500;
    color: #207D94;
    text-decoration: none;
    border-bottom: 1px solid #E5E5E5;
  }

  .shopcom-menu-brands__shop-all:hover {
    text-decoration: underline;
  }

  /* ----------------------------------------------------------------
   * Brands: Accordion
   * ---------------------------------------------------------------- */
  .shopcom-menu-brands__accordion {
    border-bottom: 1px solid #E5E5E5;
  }

  .shopcom-menu-brands__accordion-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 12px 20px;
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 15px;
    font-weight: 500;
    color: #141414;
    border: none;
    background: transparent;
    cursor: pointer;
    text-align: start;
  }

  .shopcom-menu-brands__accordion-toggle:hover {
    background-color: #F5F5F5;
  }

  .shopcom-menu-brands__accordion-toggle:focus-visible {
    outline: 2px solid rgb(var(--color-focus, 32, 125, 148));
    outline-offset: -2px;
  }

  .shopcom-menu-brands__accordion-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: #999999;
    transition: transform 0.2s ease;
  }

  .shopcom-menu-brands__accordion-icon svg {
    width: 16px;
    height: 16px;
  }

  .shopcom-menu-brands__accordion-toggle[aria-expanded='true'] .shopcom-menu-brands__accordion-icon {
    transform: rotate(45deg);
  }

  .shopcom-menu-brands__accordion-content {
    padding: 8px 20px 16px;
  }

  /* ----------------------------------------------------------------
   * Brands: Grid (3-column circular logos)
   * ---------------------------------------------------------------- */
  .shopcom-menu-brands__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px 12px;
  }

  .shopcom-menu-brands__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: #141414;
  }

  .shopcom-menu-brands__item:hover .shopcom-menu-brands__logo {
    border-color: #207D94;
  }

  .shopcom-menu-brands__logo {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid #E5E5E5;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F5F5F5;
    transition: border-color 0.15s ease;
  }

  .shopcom-menu-brands__logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .shopcom-menu-brands__logo--placeholder {
    font-family: var(--font-heading--family, 'DM Sans', sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: #999999;
  }

  .shopcom-menu-brands__name {
    font-family: var(--font-body--family, 'DM Sans', sans-serif);
    font-size: 11px;
    font-weight: 400;
    color: #555555;
    text-align: center;
    max-width: 80px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ----------------------------------------------------------------
   * Mobile: full viewport width
   * ---------------------------------------------------------------- */
  @media screen and (max-width: 749px) {
    .shopcom-menu-drawer {
      max-width: 100%;
    }
  }

  /* ----------------------------------------------------------------
