{% doc %}
  SHOP.COM Menu Icon

  Renders an inline SVG icon for use in the mega menu Account and Features sections.

  @param {string} icon - Icon name (required). One of: account, track-orders, reorder, help, shopping-list, list-manager, egifts, price-alerts, shopbuddy, deals, nutri-physical
  @param {string} [class] - Additional CSS classes

  @example
  {% render 'shopcom-menu-icons', icon: 'account' %}
{% enddoc %}

{% liquid
  assign icon = icon | default: ''
  assign class = class | default: ''

  unless icon != blank
    break
  endunless
%}

{%- case icon -%}
  {%- when 'account' -%}
    <svg class="shopcom-menu-icon {{ class }}" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
