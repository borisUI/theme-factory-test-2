                "icon": "none",
                "width": 20
              },
              "blocks": {
                "faq_ans2_R1u2V3": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Mix one scoop with 8-12oz of water, your favorite smoothie, or juice. For best results, take it first thing in the morning as part of your daily routine.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
