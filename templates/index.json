              "type": "_accordion-row",
              "settings": {
                "heading": "What makes Factor Form different from other supplement brands?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "faq_ans1_P9s0T1": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Factor Form is built from real food ingredients, designed by registered dietitians, and rigorously third-party tested. Every product is made with whole food sources rather than synthetic compounds.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
