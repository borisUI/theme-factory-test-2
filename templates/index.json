              "blocks": {
                "faq_ans3_T3w4X5": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes. Every batch of Factor Form products undergoes rigorous third-party testing for purity, potency, and safety. We believe in full transparency and publish our test results.</p>",
